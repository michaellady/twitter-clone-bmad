generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  bio          String   @default("")
  avatarUrl    String   @default("/default-avatar.png")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
